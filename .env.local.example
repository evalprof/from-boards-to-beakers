# Set these in Vercel project settings (and locally in .env.local for dev).
# Production + Preview environments both need every var below.

# Supabase — public read-only client (browser + server reads use this).
# Also used by Phase 4 magic-link auth (cookie-aware client in lib/supabase-server.ts
# and the browser client inside components/LoginForm.tsx and SignOutButton.tsx).
NEXT_PUBLIC_SUPABASE_URL=https://ppukvlevivjjlimcxqxe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
  # ↑ from Supabase dashboard → Project Settings → API → "Publishable key"

# Supabase — service role (bypasses RLS; used by /api/* routes and seed script).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
  # ↑ from Supabase dashboard → Project Settings → API → "Secret keys"

# Resend — email notifications on new submissions.
RESEND_API_KEY=re_...
  # ↑ from resend.com/api-keys
RESEND_FROM_EMAIL=onboarding@resend.dev
  # ↑ Resend's shared sandbox sender; can only deliver to the Resend account email.
  # To send to other recipients, verify a custom domain in Resend (Phase 5).
SUBMISSIONS_NOTIFY_EMAIL=evalprof2@gmail.com
  # ↑ Must match the email registered on the Resend account until a
  # custom domain is verified.
