# Set these in Vercel project settings (and locally in .env.local for dev)

# Supabase — public read-only client (browser + server reads use this)
NEXT_PUBLIC_SUPABASE_URL=https://ppukvlevivjjlimcxqxe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (from Supabase dashboard → Project Settings → API → anon public key)

# Supabase — service role (bypasses RLS; used by /api routes and seed script)
SUPABASE_SERVICE_ROLE_KEY=eyJ... (from Supabase dashboard → Project Settings → API → service_role secret)

# Resend — email notifications on new submissions
RESEND_API_KEY=re_...           (from resend.com/api-keys)
RESEND_FROM_EMAIL=onboarding@resend.dev    (default until you verify a custom domain)
SUBMISSIONS_NOTIFY_EMAIL=evalprof2@gmail.com
